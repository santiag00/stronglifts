{
  "$schema": "https://raw.githubusercontent.com/nicegram/nicegram-ios/master/nicegram-assistant-packages/nicegram-assistant/src/schemas/schema.json",
  "identifier": "default",
  "description": "Default capability for the app",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "notification:default",
    "notification:allow-is-permission-granted",
    "notification:allow-request-permission",
    "notification:allow-notify",
    "notification:allow-show"
  ]
}

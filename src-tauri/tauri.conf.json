{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-config-schema/schema.json",
  "productName": "Stronglifts",
  "version": "0.1.0",
  "identifier": "com.stronglifts.app",
  "build": {
    "frontendDist": "../src"
  },
  "bundle": {
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon.png"
    ]
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Stronglifts 5×5",
        "width": 480,
        "height": 900,
        "resizable": true,
        "minWidth": 400,
        "minHeight": 700
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {}

}
